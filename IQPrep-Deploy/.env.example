# IQPrep — copy to .env and fill values. Never commit .env.

# Groq (required for AI questions, evaluation, Jarvis, resume, daily challenge)
GROQ_API_KEY=

# MySQL
DB_URL=jdbc:mysql://db:3306/iqprep_db
DB_USERNAME=root
DB_PASSWORD=change_me

# Optional: CORS (comma-separated origins)
# APP_CORS_ALLOWED_ORIGINS=https://your-frontend.com,http://localhost:5500

# Optional: rate limits
# RATE_LIMIT_QUESTIONS_PER_MIN=24
# RATE_LIMIT_EVALUATE_PER_MIN=36
